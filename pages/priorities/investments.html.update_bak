    <style>
        .investments-intro {
            background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-primary) 100%);
            color: white;
            padding: 4rem 0;
            text-align: center;
        }
        .investments-intro h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .investments-intro p {
            font-size: 1.25rem;
            max-width: 800px;
            margin: 0 auto;
        }
        .investment-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }
        .stat-item {
            text-align: center;
        }
        .stat-number {
            font-size: 3rem;
            font-weight: 700;
            display: block;
        }
        .stat-label {
            font-size: 0.9rem;
            opacity: 0.9;
        }
        .investments-table-section {
            padding: 3rem 0;
        }
        .table-controls {
            margin-bottom: 2rem;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .search-input {
            padding: 0.75rem 1rem;
            border: 2px solid var(--color-border);
            border-radius: 8px;
            font-family: var(--font-sans);
            flex: 1;
            min-width: 250px;
        }
        .investments-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-radius: 8px;
            overflow: hidden;
        }
        .investments-table thead {
            background: var(--color-primary);
            color: white;
        }
        .investments-table th {
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            cursor: pointer;
            user-select: none;
        }
        .investments-table th:hover {
            background: rgba(255,255,255,0.1);
        }
        .investments-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--color-border);
        }
        .investments-table tbody tr:hover {
            background: var(--color-background);
        }
        .amount-cell {
            font-weight: 600;
            color: var(--color-accent);
        }
        .sector-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: var(--color-secondary);
            color: white;
            border-radius: 20px;
            font-size: 0.85rem;
        }
        @media (max-width: 768px) {
            .investments-table {
                font-size: 0.85rem;
            }
            .investments-table th,
            .investments-table td {
                padding: 0.5rem;
            }
        }
    </style>
</head>
