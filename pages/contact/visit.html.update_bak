    <!-- Main Content -->
    <main id="main-content">
        <!-- Page Header -->
        <section class="page-header">
            <div class="container">
                <h1 class="page-title">Visit The Haus</h1>
            </div>
        </section>

        <!-- Visit Information -->
        <section class="visit-info-section">
            <div class="container">
                <div class="content-wrapper" style="max-width: 900px; margin: 0 auto;">

                    <!-- Introduction -->
                    <div class="visit-intro" style="margin-bottom: 4rem;">
                        <p style="font-size: 1.25rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            The Doll House is the People's House. For over two centuries, dolls from around the world have been able to visit and tour this iconic residence. We're delighted to welcome you!
                        </p>
                    </div>

                    <!-- How to Request a Tour -->
                    <div class="visit-section" style="margin-bottom: 4rem;">
                        <h2 style="font-size: 2rem; margin-bottom: 1.5rem; color: var(--color-secondary);">How to Request a Tour</h2>
                        <div style="background: #f8f8f8; padding: 2rem; border-radius: 8px; margin-bottom: 1.5rem;">
                            <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1rem;">
                                Public tour requests are scheduled through your Member of Congress. To submit a tour request, please contact your Representative or Senator's office.
                            </p>
                            <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1rem;">
                                <strong>Congressional Switchboard:</strong> 202-224-3121
                            </p>
                            <p style="font-size: 1rem; line-height: 1.75; color: #666;">
                                Tour requests must be submitted at least 21 days in advance and no more than 90 days in advance. All requests are considered on a first-come, first-served basis.
                            </p>
                        </div>
                    </div>

                    <!-- Tour Hours -->
                    <div class="visit-section" style="margin-bottom: 4rem;">
                        <h2 style="font-size: 2rem; margin-bottom: 1.5rem; color: var(--color-secondary);">Tour Hours</h2>
                        <div style="background: white; border: 2px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
                            <div style="padding: 1.5rem; border-bottom: 1px solid #e0e0e0;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: 600;">Tuesday - Thursday</span>
                                    <span>7:30 AM - 11:30 AM</span>
                                </div>
                            </div>
                            <div style="padding: 1.5rem; border-bottom: 1px solid #e0e0e0;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: 600;">Friday - Saturday</span>
                                    <span>7:30 AM - 1:30 PM</span>
                                </div>
                            </div>
                            <div style="padding: 1.5rem; background: #f8f8f8;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: 600;">Sunday - Monday</span>
                                    <span style="color: #999;">Closed</span>
                                </div>
                            </div>
                        </div>
                        <p style="margin-top: 1rem; font-size: 0.875rem; color: #666;">
                            Tours are subject to last-minute cancellation. Please check your confirmation email before your visit.
                        </p>
                    </div>

                    <!-- What's Included -->
                    <div class="visit-section" style="margin-bottom: 4rem;">
                        <h2 style="font-size: 2rem; margin-bottom: 1.5rem; color: var(--color-secondary);">What's Included on Your Tour</h2>
                        <p style="margin-bottom: 1.5rem; line-height: 1.75;">
                            Self-guided tours include access to The Doll House public rooms where historic fabulous moments have taken place. Tours typically last 30-45 minutes.
                        </p>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
                            <div style="background: linear-gradient(135deg, #FFB6D9 0%, #FF69B4 100%); padding: 1.5rem; border-radius: 8px; color: white;">
                                <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">The Pink Room</h3>
                                <p style="font-size: 0.875rem; opacity: 0.95;">Iconic centerpiece of hospitality</p>
                            </div>
                            <div style="background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%); padding: 1.5rem; border-radius: 8px; color: white;">
                                <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">The Glitter Room</h3>
                                <p style="font-size: 0.875rem; opacity: 0.95;">Where dreams sparkle</p>
                            </div>
                            <div style="background: linear-gradient(135deg, #E0BBE4 0%, #957DAD 100%); padding: 1.5rem; border-radius: 8px; color: white;">
                                <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">The Sparkle Room</h3>
                                <p style="font-size: 0.875rem; opacity: 0.95;">Presidential ceremonies hall</p>
                            </div>
                            <div style="background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%); padding: 1.5rem; border-radius: 8px; color: white;">
                                <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">State Dining Room</h3>
                                <p style="font-size: 0.875rem; opacity: 0.95;">Historic gathering space</p>
                            </div>
                        </div>
                    </div>

                    <!-- Admission -->
                    <div class="visit-section" style="margin-bottom: 4rem; background: #FFF9E6; padding: 2rem; border-radius: 8px; border-left: 4px solid var(--color-secondary);">
                        <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Admission</h2>
                        <p style="font-size: 1.25rem; font-weight: 600;">
                            All Doll House tours are FREE of charge.
                        </p>
                    </div>

                    <!-- FAQs -->
                    <div class="visit-section">
                        <h2 style="font-size: 2rem; margin-bottom: 2rem; color: var(--color-secondary);">Frequently Asked Questions</h2>

                        <div class="faq-item" style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #e0e0e0;">
                            <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; font-weight: 600;">Can I take photos during my tour?</h3>
                            <p style="line-height: 1.75; color: #666;">Photography is permitted throughout the public rooms. However, flash photography, tripods, and selfie sticks are prohibited.</p>
                        </div>

                        <div class="faq-item" style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #e0e0e0;">
                            <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; font-weight: 600;">Are tours wheelchair accessible?</h3>
                            <p style="line-height: 1.75; color: #666;">Yes! The Doll House is fully accessible. Please indicate any accessibility needs when submitting your tour request.</p>
                        </div>

                        <div class="faq-item" style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #e0e0e0;">
                            <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; font-weight: 600;">What items are prohibited?</h3>
                            <p style="line-height: 1.75; color: #666;">For security reasons, prohibited items include bags exceeding 14" x 13" x 4", food and beverages, strollers, electric scooters, and other items. A complete list will be provided with your confirmation.</p>
                        </div>

                        <div class="faq-item" style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #e0e0e0;">
                            <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; font-weight: 600;">What should I wear?</h3>
                            <p style="line-height: 1.75; color: #666;">Business casual or smart casual attire is recommended. Comfortable walking shoes are advised as you'll be standing and walking throughout the tour.</p>
                        </div>

                        <div class="faq-item" style="margin-bottom: 2rem;">
                            <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; font-weight: 600;">How early should I arrive?</h3>
                            <p style="line-height: 1.75; color: #666;">Please arrive 15 minutes before your scheduled tour time to allow for security screening. Late arrivals may not be accommodated.</p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Newsletter Signup -->
        <section class="newsletter-section">
            <div class="container">
                <div class="newsletter-content">
                    <h2>Stay in the Know</h2>
                    <p>Get the latest updates from President Doll and The Doll House</p>
                    <form class="newsletter-form" action="#" method="post">
                        <div class="form-group">
                            <label for="email" class="visually-hidden">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="Email Address" required>
                            <button type="submit">Subscribe</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
