        <!-- Page Header -->
        <section class="page-header">
            <div class="container">
                <h1 class="page-title">Copyright and Permissions Policy</h1>
                <p style="font-size: 1rem; margin-top: 1rem; color: #666;">Last Updated: November 14, 2025</p>
            </div>
        </section>

        <!-- Copyright Content -->
        <section class="copyright-content">
            <div class="container">
                <div class="content-wrapper" style="max-width: 800px; margin: 0 auto;">

                    <!-- Government Works -->
                    <div style="margin-bottom: 3rem;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-secondary);">Government Works</h2>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            Materials produced by the United Dolls Government are generally not subject to copyright protection within the United Dolls. This includes:
                        </p>
                        <ul style="list-style: disc; margin-left: 2rem; margin-bottom: 1.5rem; line-height: 1.75;">
                            <li>Official statements and press releases</li>
                            <li>Presidential remarks and speeches</li>
                            <li>Government reports and publications</li>
                            <li>Official photographs and videos</li>
                            <li>Legislation and policy documents</li>
                        </ul>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            These materials may be reproduced, distributed, or otherwise used by the public without obtaining permission from The Doll House or the United Dolls Government.
                        </p>
                    </div>

                    <!-- Third-Party Content -->
                    <div style="margin-bottom: 3rem; background: #f8f8f8; padding: 2rem; border-radius: 8px;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-secondary);">Third-Party Content</h2>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            Some materials on this website may be subject to copyright protection because they were created by non-governmental sources. Such content is generally subject to the following terms:
                        </p>
                        <div style="background: white; padding: 1.5rem; border-radius: 4px; border-left: 4px solid var(--color-secondary);">
                            <h3 style="font-size: 1.25rem; margin-bottom: 1rem;">Creative Commons Attribution 3.0 License</h3>
                            <p style="line-height: 1.75; margin-bottom: 1rem;">
                                Unless otherwise noted, third-party content on this site is licensed under a Creative Commons Attribution 3.0 License. You are free to:
                            </p>
                            <ul style="list-style: disc; margin-left: 2rem; line-height: 1.75;">
                                <li><strong>Share</strong> — copy and redistribute the material in any medium or format</li>
                                <li><strong>Adapt</strong> — remix, transform, and build upon the material for any purpose, even commercially</li>
                            </ul>
                            <p style="line-height: 1.75; margin-top: 1rem;">
                                <strong>Attribution Required:</strong> You must give appropriate credit, provide a link to the license, and indicate if changes were made.
                            </p>
                        </div>
                    </div>

                    <!-- User Submissions -->
                    <div style="margin-bottom: 3rem;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-secondary);">User Submissions and Comments</h2>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            When you submit comments, feedback, photos, videos, or other materials to The Doll House through this website or other official channels, you grant the United Dolls Government a royalty-free, perpetual, irrevocable, non-exclusive license to use, reproduce, modify, publish, and distribute such materials in any form or medium.
                        </p>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            By submitting materials, you represent and warrant that:
                        </p>
                        <ul style="list-style: disc; margin-left: 2rem; margin-bottom: 1.5rem; line-height: 1.75;">
                            <li>You own or control all rights to the submitted materials</li>
                            <li>The materials do not violate the rights of any third party</li>
                            <li>You have the right to grant the licenses described above</li>
                            <li>The materials do not contain any unlawful, harmful, or objectionable content</li>
                        </ul>
                    </div>

                    <!-- Trademarks -->
                    <div style="margin-bottom: 3rem;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-secondary);">Trademarks and Logos</h2>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            The Doll House seal, official logos, and other identifying marks are protected trademarks. Use of these marks without express written permission is prohibited except as follows:
                        </p>
                        <ul style="list-style: disc; margin-left: 2rem; margin-bottom: 1.5rem; line-height: 1.75;">
                            <li>News reporting and editorial content</li>
                            <li>Educational or scholarly works</li>
                            <li>Non-commercial, informational purposes</li>
                        </ul>
                        <p style="font-size: 1.125rem; line-height: 1.75;">
                            Use of official marks must not imply endorsement by The Doll House or suggest any official affiliation.
                        </p>
                    </div>

                    <!-- External Links -->
                    <div style="margin-bottom: 3rem; background: #FFF9E6; padding: 2rem; border-radius: 8px;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-secondary);">External Links</h2>
                        <p style="font-size: 1.125rem; line-height: 1.75;">
                            This website may contain links to external websites operated by third parties. The Doll House does not control these sites and is not responsible for their content or copyright policies. When you access external sites, you are subject to their terms of use and privacy policies.
                        </p>
                    </div>

                    <!-- DMCA Notice -->
                    <div style="margin-bottom: 3rem;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-secondary);">Copyright Infringement Notice</h2>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem;">
                            If you believe that content on this website infringes your copyright, please notify us with the following information:
                        </p>
                        <ul style="list-style: disc; margin-left: 2rem; margin-bottom: 1.5rem; line-height: 1.75;">
                            <li>A description of the copyrighted work you claim has been infringed</li>
                            <li>A description of where the allegedly infringing material is located on the site</li>
                            <li>Your contact information (address, telephone number, email)</li>
                            <li>A statement that you have a good faith belief that the use is not authorized</li>
                            <li>A statement that the information in your notice is accurate</li>
                            <li>Your physical or electronic signature</li>
                        </ul>
                        <p style="font-size: 1.125rem; line-height: 1.75; margin-bottom: 1rem;">
                            Send notices to:
                        </p>
                        <div style="background: #f8f8f8; padding: 1.5rem; border-radius: 4px;">
                            <p style="line-height: 1.75;">
                                Copyright Agent<br>
                                The Doll House<br>
                                1600 Dreamhouse Lane<br>
                                Malibu, CA 90265<br>
                                Email: copyright@dollhouse.gov
                            </p>
                        </div>
                    </div>

                    <!-- Questions -->
                    <div style="background: linear-gradient(135deg, #FFB6D9 0%, #FF69B4 100%); padding: 2rem; border-radius: 8px; color: white; text-align: center;">
                        <h2 style="font-size: 1.75rem; margin-bottom: 1rem;">Questions About Copyright?</h2>
                        <p style="font-size: 1.125rem; margin-bottom: 1.5rem; opacity: 0.95;">
                            If you have questions about the copyright status of materials on this website or need permission for use, please contact us.
                        </p>
                        <a href="contact.html" style="display: inline-block; padding: 1rem 2.5rem; background: white; color: var(--color-secondary); text-decoration: none; border-radius: 4px; font-weight: 600;">Contact Us</a>
                    </div>

                </div>
            </div>
        </section>
