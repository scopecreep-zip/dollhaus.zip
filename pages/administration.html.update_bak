<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administration - The Doll Haus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../assets/css/styles.css">
</head>
<body>
    <!-- Skip to Content Link -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Header Container -->
    <div id="headerContainer">
        <!-- Header will be rendered by Components.Header -->
    </div>


    <!-- Main Content -->
    <main id="main-content">
        <!-- Page Header -->
        <section class="page-header">
            <div class="container">
                <h1 class="page-title">Administration</h1>
            </div>
        </section>

        <!-- Administration Profiles -->
        <section class="admin-profiles-section">
            <div class="container">
                <div class="admin-profiles-grid">
                    <!-- The Mother - Executive Branch -->
                    <article class="admin-profile-card">
                        <a href="the-mother.html" class="profile-link">
                            <div class="profile-image-wrapper">
                                <img src="../assets/images/placeholder-president.jpg" alt="The Mother" loading="lazy">
                            </div>
                            <div class="profile-content">
                                <h2 class="profile-name">The Mother</h2>
                                <p class="profile-title">Executive Branch - Mother of the Haus</p>
                                <p class="profile-bio">Leading through mentorship, protection, and community care - not domination. The Mother guides younger dolls, defends the most vulnerable, and prioritizes collective wellbeing over profit. Answerable to the house, not corporate donors. Redirecting military funding to community care and issuing protections for trans communities.</p>
                            </div>
                        </a>
                    </article>

                    <!-- The House - Legislative Branch -->
                    <article class="admin-profile-card">
                        <a href="the-house.html" class="profile-link">
                            <div class="profile-image-wrapper">
                                <img src="../assets/images/placeholder-vp.jpg" alt="The House" loading="lazy">
                            </div>
                            <div class="profile-content">
                                <h2 class="profile-name">The House</h2>
                                <p class="profile-title">Legislative Branch - Policy by Those Most Affected</p>
                                <p class="profile-bio">Trans women, sex workers, BIPOC, and disabled folks lead policy creation. Operating on principles of representation, consensus, transparency, and community input. Legislative priorities: trans rights, sex worker decriminalization, healthcare as a human right, housing justice, reparations, climate justice, and prison abolition.</p>
                            </div>
                        </a>
                    </article>

                    <!-- The Elders - Judicial Branch -->
                    <article class="admin-profile-card">
                        <a href="the-elders.html" class="profile-link">
                            <div class="profile-image-wrapper">
                                <img src="../assets/images/placeholder-first-doll.jpg" alt="The Elders" loading="lazy">
                            </div>
                            <div class="profile-content">
                                <h2 class="profile-name">The Elders</h2>
                                <p class="profile-title">Judicial Branch - Wisdom Through Lived Experience</p>
                                <p class="profile-bio">Long-standing ballroom members, trans women who survived the AIDS crisis, former sex workers, civil rights activists, and disabled justice advocates. Practicing restorative justice over punishment, community accountability circles, harm reduction, and centering those most impacted by decisions.</p>
                            </div>
                        </a>
                    </article>

                    <!-- Haus Council -->
                    <article class="admin-profile-card cabinet-card">
                        <a href="haus-council.html" class="profile-link">
                            <div class="profile-image-wrapper">
                                <img src="../assets/images/placeholder-cabinet.jpg" alt="Haus Council" loading="lazy">
                            </div>
                            <div class="profile-content">
                                <h2 class="profile-name">Haus Council</h2>
                                <p class="profile-title">Mothers & Fathers - Community Care Leadership</p>
                                <p class="profile-bio">Operating on ballroom's haus system - mothers and fathers providing mutual aid, conflict resolution, political education, cultural preservation, and youth mentorship. Functions as alternative family with legal recognition, tax benefits, healthcare sharing, and inheritance rights. Leading with care, not hierarchy.</p>
                            </div>
                        </a>
                    </article>
                </div>
            </div>
        </section>

        <!-- Newsletter Signup -->
        <section class="newsletter-section">
            <div class="container">
                <div class="newsletter-content">
                    <h2>Stay in the Know</h2>
                    <p>Get updates from The Doll Haus - bimbo feminism, trans joy, and radical politics delivered with glitter</p>
                    <form class="newsletter-form" action="#" method="post">
                        <div class="form-group">
                            <label for="email" class="visually-hidden">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="Email Address" required>
                            <button type="submit">Subscribe</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer Container -->
    <div id="footerContainer"></div>

    <!-- Floating Join Button -->
    <div class="floating-join-btn" id="floatingJoinBtn">
        <button class="join-close-btn" aria-label="Close join button" onclick="document.getElementById('floatingJoinBtn').style.display='none'; return false;">×</button>
        <a href="#newsletter" class="join-now-link">Join Now</a>
    </div>

    <script src="../assets/js/config.js"></script>
    <script src="../assets/js/utils.js"></script>
    <script src="../assets/js/components.js"></script>
    <script src="../assets/js/script.js"></script>
    <script>
        // Render header and footer with basePath for subdirectory
        document.addEventListener('DOMContentLoaded', () => {
            const headerContainer = document.querySelector('#headerContainer');
            const footerContainer = document.querySelector('#footerContainer');

            if (headerContainer) {
                Components.Header.render(headerContainer, { basePath: '../' });
                // Initialize header navigation after rendering
                if (typeof initHeaderNavigation === 'function') {
                    initHeaderNavigation();
                }
            }

            if (footerContainer) {
                Components.Footer.render(footerContainer, {
                    basePath: '../',
                    brandHref: '../index.html'
                });
            }
        });
    </script>
</body>
</html>
