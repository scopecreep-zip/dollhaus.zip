        <!-- Action Categories Grid -->
        <section class="administration-section">
            <div class="container">
                <div class="admin-grid" style="max-width: 1000px; margin: 0 auto;">
                    <!-- Executive Orders -->
                    <article class="admin-card">
                        <a href="executive-orders.html" class="admin-link">
                            <div class="admin-image-wrapper" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); display: flex; align-items: center; justify-content: center; flex-direction: column; padding: 40px;">
                                <span style="color: white; font-size: 64px; margin-bottom: 20px;">📜</span>
                                <div style="text-align: center; color: white;">
                                    <h2 style="font-size: 48px; font-weight: bold; margin: 0; font-family: var(--font-serif);">87</h2>
                                    <p style="font-size: 14px; margin: 8px 0 0; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Total Orders</p>
                                </div>
                            </div>
                            <div class="admin-info">
                                <h3 class="admin-name">Executive Orders</h3>
                                <p class="admin-title">Official directives with the force of law, shaping administration policy and priorities.</p>
                            </div>
                        </a>
