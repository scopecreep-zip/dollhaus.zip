        <!-- Page Header -->
        <section class="page-header">
            <div class="container">
                <h1 class="page-title">Executive Orders</h1>
                <p style="text-align: center; max-width: 700px; margin: 20px auto 0; color: var(--color-text-dark); opacity: 0.8;">
                    <a href="presidential-actions.html" style="color: var(--color-primary); text-decoration: none;">← Back to Presidential Actions</a>
                </p>
            </div>
        </section>

        <!-- Filter Options -->
        <section class="news-filter-section">
            <div class="container">
                <nav class="news-filter" aria-label="Filter executive orders">
                    <button class="filter-btn active" data-filter="all">All Orders</button>
                    <button class="filter-btn" data-filter="economy">Economy</button>
                    <button class="filter-btn" data-filter="education">Education</button>
                    <button class="filter-btn" data-filter="healthcare">Healthcare</button>
                    <button class="filter-btn" data-filter="climate">Climate</button>
                    <button class="filter-btn" data-filter="civil-rights">Civil Rights</button>
                </nav>
            </div>
        </section>

        <!-- Executive Orders List -->
        <section class="news-list-section">
            <div class="container">
                <div class="news-list">
                    <!-- EO 87 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 87</span>
                            <span class="news-date">November 14, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Expanding Dream Opportunities in Rural Communities</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Directs federal agencies to prioritize investment and resources in underserved rural doll communities to ensure equitable access to dream fulfillment programs.</p>
                    </article>

                    <!-- EO 86 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 86</span>
                            <span class="news-date">November 12, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Fashion Freedom and Self-Expression</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Establishes comprehensive protections for dolls to express themselves through fashion choices without discrimination or restriction in public and private settings.</p>
                    </article>

                    <!-- EO 85 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 85</span>
                            <span class="news-date">November 10, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Climate Action and Environmental Justice</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Commits the administration to achieving carbon neutrality by 2030 and ensures environmental protections benefit all doll communities equally.</p>
                    </article>

                    <!-- EO 84 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 84</span>
                            <span class="news-date">November 8, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Universal Dreamcare Implementation</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Establishes framework for implementing comprehensive healthcare coverage for all dolls, including mental health and wellness services.</p>
                    </article>

                    <!-- EO 83 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 83</span>
                            <span class="news-date">November 6, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on STEM Education and Innovation</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Directs increased federal investment in science, technology, engineering, and mathematics education programs to prepare dolls for careers of the future.</p>
                    </article>

                    <!-- EO 82 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 82</span>
                            <span class="news-date">November 4, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Supporting Doll Entrepreneurs and Small Businesses</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Creates Dream Ventures program providing grants, loans, and mentorship to dolls starting businesses and pursuing entrepreneurial dreams.</p>
                    </article>

                    <!-- EO 81 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 81</span>
                            <span class="news-date">November 2, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Diversity, Equity, and Inclusion in Government</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Mandates diversity and inclusion initiatives across all federal agencies to ensure government reflects the diversity of all doll communities.</p>
                    </article>

                    <!-- EO 80 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 80</span>
                            <span class="news-date">October 30, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Infrastructure Modernization and Dreamhouse Development</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Authorizes comprehensive infrastructure investments to modernize dreamhouses, transportation, and community facilities nationwide.</p>
                    </article>

                    <!-- EO 79 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 79</span>
                            <span class="news-date">October 28, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Protecting Workers' Rights and Fair Wages</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Strengthens labor protections and establishes fair wage standards ensuring all working dolls receive equitable compensation and benefits.</p>
                    </article>

                    <!-- EO 78 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 78</span>
                            <span class="news-date">October 26, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Arts, Culture, and Creative Expression</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Establishes Creative Dreams Fund supporting arts and cultural programs that celebrate diverse voices and creative expression across doll communities.</p>
                    </article>

                    <!-- EO 77 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 77</span>
                            <span class="news-date">October 24, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Digital Equity and Technology Access</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Ensures all dolls have access to high-speed internet, digital devices, and technology education to participate fully in the digital economy.</p>
                    </article>

                    <!-- EO 76 -->
                    <article class="news-item">
                        <div class="news-meta">
                            <span class="news-category">EO 76</span>
                            <span class="news-date">October 22, 2025</span>
                        </div>
                        <h2 class="news-title">
                            <a href="#">Executive Order on Youth Empowerment and Mentorship</a>
                        </h2>
                        <p style="margin-top: 12px; color: var(--color-text-dark); opacity: 0.8;">Creates national mentorship programs connecting young dolls with role models and providing resources for personal and professional development.</p>
                    </article>
                </div>

