    <!-- Main Content -->
    <main id="main-content">
        <!-- Page Header -->
        <section class="page-header">
            <div class="container">
                <h1 class="page-title">The Haus Council</h1>
            </div>
        </section>

        <!-- Cabinet Introduction -->
        <section style="padding: var(--spacing-80) 0; background: var(--color-white);">
            <div class="container" style="max-width: 900px;">
                <div style="text-align: center;">
                    <h2 style="color: var(--color-primary); margin-bottom: 32px;">About The Haus Council</h2>
                    <p style="font-size: 18px; line-height: 1.8; margin-bottom: 24px;">The Haus Council serves as the executive leadership circle under The Mother (President Barbie), representing the most trans-inclusive, ballroom-rooted, and unapologetically femme governance in history. These exceptional leaders - majority trans women of color, sex workers, and ballroom legends - bring lived experience from the margins to guide our haus toward liberation, not reform.</p>
                    <p style="font-size: 18px; line-height: 1.8; margin-bottom: 24px;">Each Council member oversees liberation work in their domain: trans healthcare access, sex worker rights, mutual aid coordination, community defense, ballroom preservation, and abolition. Together, they form a powerful chosen family dedicated to protecting the dolls through bimbo feminist politics and antifascist organizing.</p>
                    <p style="font-size: 18px; line-height: 1.8; margin: 0;">Under The Mother's leadership, the Haus Council operates through consensus and collective care - working alongside The House (legislative) and The Elders (judicial) to prove you can govern with glamour AND radical politics, intelligence AND hyperfemininity, fierceness AND compassion.</p>
                </div>
            </div>
        </section>

        <!-- Cabinet Members Grid -->
        <section style="padding: var(--spacing-100) 0; background: var(--color-light);">
            <div class="container" style="max-width: 1400px;">
                <h2 style="color: var(--color-primary); text-align: center; margin-bottom: 60px;">Haus Council Members</h2>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 40px;">
                    <!-- Cabinet Member 1 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-cabinet.jpg" alt="Secretary of Fashion" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Christie O'Neill</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Trans Liberation & Gender Euphoria</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Guaranteeing gender-affirming healthcare for all, banning anti-trans legislation, and ensuring trans women - especially Black & Latina trans women - have safety, dignity, and celebration.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 2 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-1.jpg" alt="Secretary of Dreams" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Nikki Watanabe</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Sex Worker Rights & Labor Justice</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Overseeing programs that help dolls discover and pursue their passions, from career counseling to entrepreneurship support and creative arts funding.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 3 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-2.jpg" alt="Secretary of Innovation" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Raquelle Kim</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Innovation & Technology</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Driving technological advancement and digital transformation, investing in AI, clean tech, and emerging technologies to keep the nation competitive.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 4 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-3.jpg" alt="Secretary of Wellness" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Dr. Summer Gordon</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Health & Wellness</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Leading public health initiatives, expanding healthcare access, and promoting holistic wellness including mental health, fitness, and preventive care.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 5 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-4.jpg" alt="Secretary of Education" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Stacie Roberts</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Education</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Championing educational excellence and equity, modernizing schools, supporting teachers, and ensuring every doll has access to quality learning opportunities.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 6 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-president.jpg" alt="Secretary of Joy" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Midge Hadley</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Joy & Happiness</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Promoting national well-being through arts, culture, recreation, and community-building initiatives that bring dolls together in celebration and connection.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 7 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-vp.jpg" alt="Secretary of Adventure" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Becky Armstrong</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Parks & Adventure</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Protecting national parks and natural resources while ensuring outdoor recreation is accessible to all dolls, with special focus on inclusive design.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 8 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-first-doll.jpg" alt="Secretary of Commerce" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Courtney Chen</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Commerce</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Fostering economic growth, supporting small businesses, promoting trade, and ensuring economic opportunities reach all communities nationwide.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 9 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-cabinet.jpg" alt="Secretary of Housing" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Kayla Martinez</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Dream Homes</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Ensuring every doll has access to safe, affordable housing and working to end homelessness through innovative housing solutions and support services.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 10 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-1.jpg" alt="Secretary of Transportation" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Dana Thompson</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Transportation</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Modernizing transportation infrastructure, promoting electric vehicles and public transit, and ensuring safe, efficient mobility for all dolls.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 11 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-2.jpg" alt="Secretary of Energy" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Dr. Renee Park</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Energy & Climate</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Leading the transition to clean energy, combating climate change, and ensuring energy independence while creating green jobs across the nation.</p>
                        </div>
                    </article>

                    <!-- Cabinet Member 12 -->
                    <article style="background: var(--color-white); border-radius: var(--radius-large); overflow: hidden; box-shadow: var(--shadow-natural); transition: all 0.3s ease; border: 2px solid var(--color-pale);">
                        <div style="width: 100%; aspect-ratio: 3/4; background: linear-gradient(135deg, var(--color-lavender) 0%, var(--color-pale) 100%); overflow: hidden;">
                            <img src="../../assets/images/placeholder-gallery-3.jpg" alt="Secretary of Labor" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 32px;">
                            <h3 style="color: var(--color-text-dark); margin-bottom: 8px; font-size: 22px;">Grace Williams</h3>
                            <p style="color: var(--color-primary); font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px;">Secretary of Labor</p>
                            <p style="font-size: 15px; line-height: 1.6; color: var(--color-text-dark); margin: 0;">Protecting workers' rights, promoting fair wages and safe workplaces, and preparing the workforce for the jobs of tomorrow through training programs.</p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <!-- Cabinet Priorities -->
        <section style="padding: var(--spacing-100) 0; background: var(--color-white);">
            <div class="container" style="max-width: 1200px;">
                <h2 style="color: var(--color-primary); text-align: center; margin-bottom: 60px;">Collective Priorities</h2>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 32px;">
                    <div style="text-align: center; padding: 32px;">
                        <h3 style="color: var(--color-primary); margin-bottom: 16px;">Economic Prosperity</h3>
                        <p style="font-size: 16px; line-height: 1.6; margin: 0;">Building an economy that works for all dolls through job creation, fair wages, and entrepreneurship support.</p>
                    </div>
                    <div style="text-align: center; padding: 32px;">
                        <h3 style="color: var(--color-primary); margin-bottom: 16px;">Climate Action</h3>
                        <p style="font-size: 16px; line-height: 1.6; margin: 0;">Taking bold steps to combat climate change and build a sustainable future for generations to come.</p>
                    </div>
                    <div style="text-align: center; padding: 32px;">
                        <h3 style="color: var(--color-primary); margin-bottom: 16px;">Healthcare for All</h3>
                        <p style="font-size: 16px; line-height: 1.6; margin: 0;">Ensuring every doll has access to affordable, quality healthcare including mental health services.</p>
                    </div>
                    <div style="text-align: center; padding: 32px;">
                        <h3 style="color: var(--color-primary); margin-bottom: 16px;">Education Excellence</h3>
                        <p style="font-size: 16px; line-height: 1.6; margin: 0;">Investing in schools, teachers, and students to prepare young dolls for success in the modern world.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Quote Section -->
        <section style="padding: var(--spacing-100) 0; background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-primary-accent) 100%); color: white;">
            <div class="container" style="max-width: 900px;">
                <blockquote style="text-align: center; margin: 0;">
                    <p style="font-size: 32px; font-family: var(--font-serif); line-height: 1.4; margin-bottom: 24px;">"Together, we are building a government that reflects the diversity, talent, and dreams of our entire nation. This Cabinet brings together the best and brightest to serve with purpose and passion."</p>
                    <footer style="font-size: 16px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">President Barbie</footer>
                </blockquote>
            </div>
        </section>

        <!-- Newsletter Signup -->
