                        <div style="padding: 1.5rem;">
                            <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; font-weight: 600;">Behind the Scenes</h3>
                            <p style="color: #666; font-size: 0.875rem;">28 videos</p>
                        </div>
                    </div>
                    <div style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%); height: 160px; display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem;">▶</div>
                        <div style="padding: 1.5rem;">
                            <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; font-weight: 600;">Weekly Updates</h3>
                            <p style="color: #666; font-size: 0.875rem;">156 videos</p>
                        </div>
                    </div>
                    <div style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="background: linear-gradient(135deg, #E0BBE4 0%, #957DAD 100%); height: 160px; display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem;">▶</div>
                        <div style="padding: 1.5rem;">
                            <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; font-weight: 600;">Press Briefings</h3>
                            <p style="color: #666; font-size: 0.875rem;">89 videos</p>
