        <!-- Video Controls -->
        <section class="video-controls-section">
            <div class="container">
                <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <!-- Search Bar -->
                    <div style="flex: 1; min-width: 300px;">
                        <input type="search" placeholder="Search videos..." style="width: 100%; padding: 0.75rem 1rem; border: 2px solid #ddd; border-radius: 4px; font-size: 1rem;">
                    </div>

                    <!-- Sort & Filter -->
                    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                        <select style="padding: 0.75rem 1rem; border: 2px solid #ddd; border-radius: 4px; font-size: 1rem; background: white;">
                            <option>Sort: Latest</option>
                            <option>Sort: Popular</option>
                            <option>Sort: Oldest</option>
                        </select>

                        <div style="display: flex; gap: 0.5rem;">
                            <button style="padding: 0.75rem 1.25rem; border: 2px solid var(--color-secondary); background: var(--color-secondary); color: white; border-radius: 4px; font-weight: 600; cursor: pointer;">All</button>
                            <button style="padding: 0.75rem 1.25rem; border: 2px solid #ddd; background: white; color: #333; border-radius: 4px; font-weight: 600; cursor: pointer;">Live</button>
                            <button style="padding: 0.75rem 1.25rem; border: 2px solid #ddd; background: white; color: #333; border-radius: 4px; font-weight: 600; cursor: pointer;">Shorts</button>
                            <button style="padding: 0.75rem 1.25rem; border: 2px solid #ddd; background: white; color: #333; border-radius: 4px; font-weight: 600; cursor: pointer;">Videos</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Playlists -->
        <section class="playlists-section" style="background: #f8f8f8; padding: 3rem 0;">
            <div class="container">
                <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Featured Playlists</h2>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
                    <div style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="background: linear-gradient(135deg, #FFB6D9 0%, #FF69B4 100%); height: 160px; display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem;">▶</div>
                        <div style="padding: 1.5rem;">
                            <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; font-weight: 600;">Presidential Addresses</h3>
                            <p style="color: #666; font-size: 0.875rem;">42 videos</p>
                        </div>
                    </div>
                    <div style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
