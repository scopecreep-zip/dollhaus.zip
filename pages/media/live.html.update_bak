    <!-- Main Content -->
    <main id="main-content">
        <!-- Live Status Hero -->
        <section style="background: linear-gradient(135deg, #FFB6D9 0%, #FF69B4 100%); padding: 6rem 0; text-align: center; color: white;">
            <div class="container">
                <div style="max-width: 700px; margin: 0 auto;">
                    <div style="width: 80px; height: 80px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; font-size: 2.5rem;">📡</div>
                    <h1 style="font-size: 3rem; margin-bottom: 1.5rem; font-family: var(--font-serif);">Stay tuned</h1>
                    <p style="font-size: 1.5rem; margin-bottom: 2rem; opacity: 0.95;">We'll be live again shortly</p>
                    <p style="font-size: 1.125rem; opacity: 0.9;">Sign up below to receive alerts when The Doll House goes live</p>
                </div>
            </div>
        </section>

        <!-- Newsletter Signup for Live Alerts -->
        <section style="padding: 4rem 0; background: white;">
            <div class="container">
                <div style="max-width: 600px; margin: 0 auto; text-align: center;">
                    <h2 style="font-size: 2rem; margin-bottom: 1rem;">Get Live Alerts</h2>
                    <p style="font-size: 1.125rem; margin-bottom: 2rem; color: #666;">Never miss a live event from The Doll House. We'll email you when we're about to go live.</p>
                    <form action="#" method="post" style="display: flex; gap: 1rem; max-width: 500px; margin: 0 auto;">
                        <input type="email" placeholder="Your Email Address" required style="flex: 1; padding: 1rem; border: 2px solid #ddd; border-radius: 4px; font-size: 1rem;">
                        <button type="submit" style="padding: 1rem 2rem; background: var(--color-secondary); color: white; border: none; border-radius: 4px; font-weight: 600; cursor: pointer; font-size: 1rem;">Subscribe</button>
                    </form>
                </div>
            </div>
        </section>

        <!-- Recent Videos -->
        <section style="padding: 4rem 0; background: #f8f8f8;">
            <div class="container">
                <h2 style="font-size: 2rem; margin-bottom: 2rem; text-align: center;">Recent Live Streams</h2>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">

                    <!-- Video 1 -->
                    <article style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="position: relative; background: #ddd; padding-bottom: 56.25%;">
                            <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.8); color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.875rem; font-weight: 600;">1:24:15</div>
                        </div>
                        <div style="padding: 1.25rem;">
                            <h3 style="font-size: 1rem; margin-bottom: 0.5rem; font-weight: 600;">Daily Press Briefing - November 13</h3>
                            <p style="color: #666; font-size: 0.875rem;">1.2K views • 1 day ago</p>
                        </div>
                    </article>

                    <!-- Video 2 -->
                    <article style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="position: relative; background: #ddd; padding-bottom: 56.25%;">
                            <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.8); color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.875rem; font-weight: 600;">45:22</div>
                        </div>
                        <div style="padding: 1.25rem;">
                            <h3 style="font-size: 1rem; margin-bottom: 0.5rem; font-weight: 600;">President Barbie Addresses the Nation</h3>
                            <p style="color: #666; font-size: 0.875rem;">3.5K views • 3 days ago</p>
                        </div>
                    </article>

                    <!-- Video 3 -->
                    <article style="background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="position: relative; background: #ddd; padding-bottom: 56.25%;">
                            <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.8); color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.875rem; font-weight: 600;">2:15:30</div>
                        </div>
                        <div style="padding: 1.25rem;">
                            <h3 style="font-size: 1rem; margin-bottom: 0.5rem; font-weight: 600;">Cabinet Meeting Live Coverage</h3>
                            <p style="color: #666; font-size: 0.875rem;">2.1K views • 5 days ago</p>
                        </div>
                    </article>

                </div>
                <div style="text-align: center; margin-top: 3rem;">
                    <a href="videos.html" style="display: inline-block; padding: 1rem 2.5rem; background: var(--color-secondary); color: white; text-decoration: none; border-radius: 4px; font-weight: 600;">View All Videos</a>
                </div>
            </div>
        </section>

        <!-- Text Updates Signup -->
        <section style="padding: 4rem 0; background: white;">
            <div class="container">
                <div style="max-width: 700px; margin: 0 auto; text-align: center;">
                    <h2 style="font-size: 2rem; margin-bottom: 1rem;">Sign Up for Text Updates</h2>
                    <p style="font-size: 1.125rem; margin-bottom: 2rem; color: #666;">Get breaking news and live alerts sent directly to your phone.</p>
                    <div style="background: #f8f8f8; padding: 3rem 2rem; border-radius: 8px;">
                        <p style="font-size: 1.25rem; margin-bottom: 1.5rem; font-weight: 600;">Text DOLLHOUSE to 12345</p>
                        <p style="font-size: 0.875rem; color: #666; margin-bottom: 1rem;">Standard messaging rates may apply. You can opt-out at any time by replying STOP.</p>
                        <p style="font-size: 0.75rem; color: #999;">By signing up, you agree to receive text messages from The Doll House. Message frequency varies.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Newsletter Signup -->
        <section class="newsletter-section">
            <div class="container">
                <div class="newsletter-content">
                    <h2>Stay in the Know</h2>
                    <p>Get the latest updates from President Doll and The Doll House</p>
                    <form class="newsletter-form" action="#" method="post">
                        <div class="form-group">
                            <label for="email" class="visually-hidden">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="Email Address" required>
                            <button type="submit">Subscribe</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>

